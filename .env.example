# --- ENSEMBLE ENVIRONMENT TEMPLATE (.env.example) ---

# Governance Policy Thresholds
APPROVAL_COST_THRESHOLD=0.0001
APPROVAL_TOOLS=shell_cmd,python_interpreter,delete_file,send_email,deploy,fetch_conversation_history
APPROVAL_TIMEOUT_SECONDS=300

# Active Intelligence Provider (ollama, gemini, local)
LLM_PROVIDER=gemini

# Local LLM Config (Ollama)
# Update OLLAMA_MODEL as needed (e.g., llama3.1:8b, mistral, deepseek-r1)
OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434/v1

# Cloud LLM Config (Gemini)
# Obtain your key from https://aistudio.google.com/
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-2.0-flash
