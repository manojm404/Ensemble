# ============================================================
# ENSEMBLE ENVIRONMENT TEMPLATE (.env.example)
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
# ============================================================

# --- Authentication (Local Development) ---
# Set to 'false' for local development (bypasses JWT auth).
# Set to 'true' for production with Supabase configured.
ENFORCE_AUTH=false

# --- Governance Policy Thresholds ---
APPROVAL_COST_THRESHOLD=0.0001
APPROVAL_TOOLS=shell_cmd,python_interpreter,delete_file,send_email,deploy,fetch_conversation_history
APPROVAL_TIMEOUT_SECONDS=300

# --- Active Intelligence Provider (ollama, gemini, local) ---
LLM_PROVIDER=gemini

# --- Local LLM Config (Ollama) ---
# Update OLLAMA_MODEL as needed (e.g., llama3.1:8b, mistral, deepseek-r1)
OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434/v1

# --- Cloud LLM Config (Gemini) ---
# Obtain your key from https://aistudio.google.com/
# NOTE: In multi-user mode, users provide their own keys via Settings UI.
#       This key is only used as a fallback or for single-user mode.
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-2.0-flash

# ============================================================
# Phase 1: Supabase Integration (Required for Multi-User Mode)
# ============================================================
# Create a project at https://app.supabase.com
# Then run schema/001_supabase_schema.sql in the SQL Editor.

# Your Supabase project URL (found in Project Settings > API)
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key (safe to expose in frontend, but keep in .env for backend)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key (SECRET - NEVER expose to frontend or commit to git!)
# This key bypasses Row Level Security and has full database access.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT secret for token validation (same as your Supabase JWT secret in Project Settings > API)
# If not set, the system will attempt to derive it from SUPABASE_SERVICE_ROLE_KEY
JWT_SECRET=your-jwt-secret-from-supabase-settings

# ============================================================
# Security Configuration
# ============================================================

# Encryption key for API key storage (AES-256 via Fernet)
# Generate a new one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
API_KEY_ENCRYPTION_KEY=generate-this-with-python-command-above

# CORS allowed origins (comma-separated, use * for development only)
CORS_ORIGINS=http://localhost:8080,http://localhost:3000,http://127.0.0.1:8080

# Rate limiting: maximum requests per minute per user
RATE_LIMIT_PER_MINUTE=100

# ============================================================
# Workspace Configuration
# ============================================================

# Directory for user workspaces (auto-created if not exists)
WORKSPACE_DIR=data/workspace

# ============================================================
# Monitoring & Observability (Optional)
# ============================================================

# Sentry DSN for error tracking (get free account at https://sentry.io)
# SENTRY_DSN=https://your-sentry-dsn

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
