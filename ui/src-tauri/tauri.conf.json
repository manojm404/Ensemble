{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Ensemble",
  "version": "1.0.0",
  "identifier": "com.ensemble.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Ensemble — Autonomous AI Company Platform",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Autonomous AI Company Platform",
    "longDescription": "Build, orchestrate, and govern teams of AI agents with a no-code visual studio, local LLMs, and human-in-the-loop controls.",
    "copyright": "© 2026 Ensemble",
    "category": "DeveloperTool",
    "externalBin": [
      "binaries/ensemble-backend"
    ]
  },
  "plugins": {
    "shell": {},
    "log": {}
  }
}
